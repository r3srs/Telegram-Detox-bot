[Unit]
Description=Telegram Detox Locker Worker
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/tg_detox_locker
EnvironmentFile=/opt/tg_detox_locker/.env
ExecStart=/opt/tg_detox_locker/.venv/bin/python -m tg_detox_locker.worker
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
